# Copy this file to .env.local and fill with your real values.
# Get these from https://supabase.com/dashboard → your project → Project Settings → API

# Public keys — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only keys — NEVER expose in the browser or commit
# Used by scripts/ (seed, admin tasks). Not needed for the Next.js app itself.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key